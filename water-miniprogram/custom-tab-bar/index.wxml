<view class="tab-bar">
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tab-item {{selected === index ? 'active' : ''}}" 
    data-path="{{item.pagePath}}" 
    data-index="{{index}}" 
    bindtap="switchTab"
  >
    <view class="icon-wrapper">
      <image class="tab-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" mode="aspectFit"></image>
      <view class="badge" wx:if="{{index === 1 && cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
    </view>
  </view>
</view>
