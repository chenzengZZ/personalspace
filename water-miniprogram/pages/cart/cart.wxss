.container {
  min-height: 100vh;
  background: #F5F9FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.cart-list {
  padding: 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26, 58, 74, 0.08);
  transition: all 0.2s ease;
  animation: slideIn 0.4s ease forwards;
}

.cart-item:nth-child(1) { animation-delay: 0.05s; }
.cart-item:nth-child(2) { animation-delay: 0.1s; }
.cart-item:nth-child(3) { animation-delay: 0.15s; }

.cart-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(26, 58, 74, 0.1);
}

.item-checkbox {
  margin-right: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #d0d8da;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  border-color: #DC143C;
  box-shadow: 0 2rpx 10rpx rgba(220, 20, 60, 0.3);
}

.check-icon {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0f4f5 0%, #e5eef0 100%);
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A4A;
  margin-bottom: 10rpx;
}

.item-price {
  margin-bottom: 16rpx;
}

.item-price .price {
  font-size: 34rpx;
  font-weight: 700;
  color: #DC143C;
  font-variant-numeric: tabular-nums;
}

.item-price .unit {
  font-size: 24rpx;
  color: #8A9BA8;
}

.item-quantity {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.quantity-btn {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #f0f4f5 0%, #e5eef0 100%);
  border: none;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #1A3A4A;
  transition: all 0.2s ease;
}

.quantity-btn:active {
  transform: scale(0.92);
  background: #d0d8da;
}

.quantity-btn.disabled {
  opacity: 0.4;
}

.quantity-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A4A;
  min-width: 52rpx;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.item-delete {
  padding: 20rpx;
  margin-left: 10rpx;
  transition: opacity 0.2s ease;
}

.item-delete:active {
  opacity: 0.6;
}

.delete-icon {
  font-size: 40rpx;
  color: #8A9BA8;
  font-weight: 300;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 40rpx;
  text-align: center;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.empty-desc {
  margin-top: 16rpx;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8A9BA8;
}

.empty-btn {
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  color: #ffffff;
  min-width: 260rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(220, 20, 60, 0.3);
  transition: transform 0.2s ease;
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  transform: scale(0.96);
}

.cart-footer {
  position: fixed;
  bottom: 180rpx;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(26, 58, 74, 0.08);
  z-index: 100;
  gap: 20rpx;
}

.footer-left {
  display: flex;
  align-items: center;
}

.footer-checkbox {
  margin-right: 16rpx;
}

.footer-text {
  font-size: 28rpx;
  color: #1A3A4A;
}

.footer-total {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.total-label {
  font-size: 28rpx;
  color: #8A9BA8;
  margin-right: 8rpx;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #DC143C;
  font-variant-numeric: tabular-nums;
}

.checkout-btn {
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  color: #ffffff;
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(220, 20, 60, 0.35);
  transition: all 0.2s ease;
}

.checkout-btn:active {
  transform: scale(0.96);
}

.checkout-btn.disabled {
  opacity: 0.5;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
