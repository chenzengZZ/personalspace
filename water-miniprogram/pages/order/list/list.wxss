.container {
  min-height: 100vh;
  background: #F5F9FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(26, 58, 74, 0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-bar {
  padding: 20rpx 24rpx 0;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  box-shadow: 0 4rpx 18rpx rgba(26, 58, 74, 0.06);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1A3A4A;
}

.search-clear {
  font-size: 32rpx;
  color: #8A9BA8;
  padding: 0 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #8A9BA8;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #DC143C;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 5rpx;
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  border-radius: 3rpx;
}

.order-list {
  padding: 24rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(26, 58, 74, 0.08);
  transition: all 0.3s ease;
  animation: slideIn 0.4s ease forwards;
}

.order-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(26, 58, 74, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(26, 58, 74, 0.06);
}

.order-id {
  font-size: 24rpx;
  color: #8A9BA8;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending {
  color: #DC143C;
}

.status-paid {
  color: #DC143C;
}

.status-delivering {
  color: #3B82F6;
}

.status-completed {
  color: #10B981;
}

.status-cancelled {
  color: #8A9BA8;
}

.order-products {
  padding: 24rpx;
}

.product-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0f4f5 0%, #e5eef0 100%);
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A4A;
  margin-bottom: 10rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  color: #DC143C;
  font-weight: 600;
}

.product-quantity {
  font-size: 26rpx;
  color: #8A9BA8;
}

.order-footer {
  padding: 24rpx;
  border-top: 1rpx solid rgba(26, 58, 74, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-total {
  font-size: 26rpx;
  color: #8A9BA8;
}

.total-text {
  margin-left: 16rpx;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #DC143C;
}

.total-price::before {
  content: '¥';
  font-size: 24rpx;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(26, 58, 74, 0.1);
  color: #8A9BA8;
  background: #ffffff;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(220, 20, 60, 0.25);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 40rpx;
  text-align: center;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.empty-desc {
  margin-top: 16rpx;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8A9BA8;
}

.empty-btn {
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  color: #ffffff;
  min-width: 260rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(220, 20, 60, 0.3);
  transition: transform 0.2s ease;
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  transform: scale(0.96);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #8A9BA8;
  font-size: 26rpx;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
