<view class="container">
  <view class="status-card status-{{order.status}}">
    <view class="status-icon">
      <text class="icon-emoji">{{order.status === 'pending' ? '💳' : order.status === 'completed' ? '✓' : '🚚'}}</text>
    </view>
    <view class="status-text">{{order.statusText}}</view>
    <view class="status-desc" wx:if="{{order.status === 'pending'}}">请在30分钟内完成支付</view>
    <view class="status-desc" wx:if="{{order.status === 'paid'}}">已支付，等待开始配送</view>
    <view class="status-desc" wx:if="{{order.status === 'delivering'}}">预计今日送达</view>
  </view>

  <view class="address-card" wx:if="{{order.address}}">
    <view class="address-icon">
      <text class="icon-emoji">📍</text>
    </view>
    <view class="address-info">
      <view class="address-user">
        <text class="user-name">{{order.address.name}}</text>
        <text class="user-phone">{{order.address.phone}}</text>
      </view>
      <view class="address-detail">{{order.address.fullAddress}}</view>
    </view>
  </view>

  <view class="address-card empty" wx:else>
    <view class="address-icon">
      <text class="icon-emoji">📍</text>
    </view>
    <view class="address-info">
      <view class="address-detail">暂无收货地址</view>
    </view>
  </view>

  <view class="products-card">
    <view class="card-title">商品信息</view>
    <view class="product-list">
      <view class="product-item" wx:for="{{order.products}}" wx:key="_id">
        <image class="product-image" src="{{item.image}}" mode="aspectFill" aria-label="{{item.name}}商品图"></image>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-meta">
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="info-card">
    <view class="card-title">订单信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">订单编号</text>
        <text class="info-value">{{order.orderNo}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.createTime}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">支付方式</text>
        <text class="info-value">{{order.payMethod || '微信支付'}}</text>
      </view>
      <view class="info-item" wx:if="{{order.payTime}}">
        <text class="info-label">支付时间</text>
        <text class="info-value">{{order.payTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.deliverTime}}">
        <text class="info-label">开始配送</text>
        <text class="info-value">{{order.deliverTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.completeTime}}">
        <text class="info-label">完成时间</text>
        <text class="info-value">{{order.completeTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.remark}}">
        <text class="info-label">订单备注</text>
        <text class="info-value">{{order.remark}}</text>
      </view>
    </view>
  </view>

  <view class="price-card">
    <view class="price-item">
      <text class="price-label">商品总额</text>
      <text class="price-value">¥{{order.productTotal}}</text>
    </view>
    <view class="price-item">
      <text class="price-label">配送费</text>
      <text class="price-value">¥{{order.deliveryFee || 0}}</text>
    </view>
    <view class="price-item total">
      <text class="price-label">实付金额</text>
      <text class="price-value">¥{{order.totalPrice}}</text>
    </view>
  </view>

  <view class="bottom-bar safe-area-bottom" wx:if="{{order.status === 'pending'}}">
    <view class="action-btn cancel" bindtap="cancelOrder" aria-label="取消订单">取消订单</view>
    <view class="action-btn pay" bindtap="payOrder" aria-label="立即支付">立即支付 ¥{{order.totalPrice}}</view>
  </view>

  <view class="bottom-bar safe-area-bottom" wx:if="{{order.status === 'paid'}}">
    <view class="action-btn pay full" bindtap="startDelivery" aria-label="开始配送">开始配送</view>
  </view>

  <view class="bottom-bar safe-area-bottom" wx:if="{{order.status === 'delivering'}}">
    <view class="action-btn pay full" bindtap="confirmReceipt" aria-label="确认收货">确认收货</view>
  </view>
</view>
