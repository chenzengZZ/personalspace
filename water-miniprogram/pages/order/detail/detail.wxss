.container {
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
}

.status-card {
  padding: 50rpx 30rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(225, 29, 72, 0.1) 0%, rgba(190, 18, 60, 0.03) 100%);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.status-card.status-completed {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.03) 100%);
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon .icon-emoji {
  font-size: 60rpx;
}

.status-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #666666;
}

.address-card {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.address-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.address-icon .icon-emoji {
  font-size: 36rpx;
}

.address-info {
  flex: 1;
}

.address-user {
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-right: 24rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #666666;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.products-card,
.info-card,
.price-card {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.product-list {
  padding: 10rpx 0;
}

.product-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  color: #E11D48;
  font-weight: 600;
}

.product-quantity {
  font-size: 26rpx;
  color: #666666;
}

.info-list {
  padding: 10rpx 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a1a;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-item:last-child {
  margin-bottom: 0;
}

.price-item.total {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.price-label {
  font-size: 26rpx;
  color: #666666;
}

.price-value {
  font-size: 26rpx;
  color: #1a1a1a;
}

.price-item.total .price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #E11D48;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.cancel {
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  color: #666666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.action-btn.pay {
  background: linear-gradient(135deg, #E11D48 0%, #BE123C 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(225, 29, 72, 0.35);
}

.action-btn.disabled {
  background: #f5f5f5;
  color: #999999;
  box-shadow: none;
}

.action-btn.full {
  width: 100%;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
