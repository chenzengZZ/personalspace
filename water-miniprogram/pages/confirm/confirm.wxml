<view class="container">
  <view class="checkout-empty-state" wx:if="{{!hasCheckoutItems}}">
    <image class="checkout-empty-image" src="/assets/icons/empty-cart.png" mode="aspectFit" />
    <text class="checkout-empty-title">还没有可结算的商品</text>
    <text class="checkout-empty-desc">先回购物车选中商品，再继续填写地址和提交订单。</text>
    <button class="checkout-empty-btn" bindtap="goToCart">返回购物车</button>
  </view>

  <block wx:else>
  <view class="order-overview">
    <view class="overview-main">
      <text class="overview-title">确认并提交订单</text>
      <text class="overview-desc">确认地址、商品和备注后，再完成这次下单。</text>
    </view>
    <view class="overview-count">
      <text class="overview-count-number">{{totalCount}}</text>
      <text class="overview-count-label">件商品</text>
    </view>
  </view>

  <!-- 地址选择 -->
  <view class="address-section" bindtap="selectAddress">
    <view class="address-header">
      <image class="location-icon" src="/assets/icons/location.png" mode="aspectFit"/>
      <text class="address-title">收货地址</text>
    </view>
    <view class="address-content" wx:if="{{address}}">
      <view class="address-top">
        <view class="address-user">
          <text class="address-name">{{address.name}}</text>
          <text class="address-phone">{{address.phone}}</text>
        </view>
        <text class="address-selected-tag">已选择</text>
      </view>
      <text class="address-detail">{{address.fullAddress}}</text>
    </view>
    <view class="address-empty" wx:else>
      <text class="address-empty-title">请选择收货地址</text>
      <text class="address-empty-desc">添加一个可配送地址，订单才能准确送到家。</text>
    </view>
    <image class="arrow-icon" src="/assets/icons/arrow-right.png" mode="aspectFit"/>
  </view>

  <!-- 商品列表 -->
  <view class="products-section">
    <view class="section-title">商品清单</view>
    <view class="product-list">
      <view class="product-item" wx:for="{{products}}" wx:key="_id">
        <image class="product-image" src="{{item.image}}" mode="aspectFill"/>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">¥{{item.price}}</text>
        </view>
        <text class="product-quantity">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 配送信息 -->
  <view class="delivery-section">
    <view class="delivery-row">
      <text class="delivery-label">配送方式</text>
      <text class="delivery-value">商家配送</text>
    </view>
    <view class="delivery-row">
      <text class="delivery-label">配送费</text>
      <text class="delivery-value {{deliveryFee == 0 ? 'free' : ''}}">
        {{deliveryFee == 0 ? '免运费' : '¥' + deliveryFee}}
      </text>
    </view>
    <text class="delivery-tip">{{deliveryFeeTip}}</text>
  </view>

  <!-- 备注 -->
  <view class="remark-section">
    <view class="remark-header">
      <text class="remark-label">订单备注</text>
      <text class="remark-helper">选填</text>
    </view>
    <view class="remark-presets">
      <view
        class="remark-preset {{remark === item ? 'active' : ''}}"
        wx:for="{{remarkPresets}}"
        wx:key="*this"
        bindtap="useRemarkPreset"
        data-value="{{item}}"
      >
        {{item}}
      </view>
    </view>
    <input 
      class="remark-input" 
      placeholder="比如：白天家里没人，放门口即可" 
      value="{{remark}}"
      bindinput="onRemarkInput"
    />
  </view>

  <!-- 价格汇总 -->
  <view class="price-section">
    <view class="price-row">
      <text class="price-label">商品总价</text>
      <text class="price-value">¥{{productTotal}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">配送费</text>
      <text class="price-value">¥{{deliveryFee}}</text>
    </view>
    <view class="price-row total">
      <text class="price-label">订单总价</text>
      <text class="price-total">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 底部提交栏 -->
  <view class="bottom-bar">
    <view class="bottom-info">
      <text class="bottom-label">合计：</text>
      <text class="bottom-price">¥{{totalPrice}}</text>
    </view>
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}" 
      bindtap="submitOrder"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : (address ? '提交订单' : '请选择收货地址')}}
    </button>
  </view>
  </block>
</view>
