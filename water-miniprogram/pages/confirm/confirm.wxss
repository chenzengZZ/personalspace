.container {
  min-height: 100vh;
  background-color: #F5F9FA;
  padding-bottom: 120rpx;
}

.order-overview {
  margin: 20rpx 20rpx 0;
  padding: 28rpx 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fff6f8 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 6rpx 20rpx rgba(220, 20, 60, 0.06);
}

.overview-main {
  flex: 1;
  padding-right: 20rpx;
}

.overview-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A4A;
}

.overview-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A9BA8;
}

.overview-count {
  min-width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(220, 20, 60, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.overview-count-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #DC143C;
}

.overview-count-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8A9BA8;
}

.checkout-empty-state {
  min-height: 100vh;
  padding: 180rpx 40rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.checkout-empty-image {
  width: 240rpx;
  height: 240rpx;
}

.checkout-empty-title {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.checkout-empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8A9BA8;
}

.checkout-empty-btn {
  margin-top: 40rpx;
  min-width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  background: #DC143C;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.checkout-empty-btn::after {
  border: none;
}

/* 地址选择 */
.address-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  position: relative;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.address-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.address-content {
  padding-right: 40rpx;
}

.address-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.address-user {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A4A;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #8A9BA8;
}

.address-selected-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #DC143C;
  background: rgba(220, 20, 60, 0.12);
}

.address-detail {
  font-size: 26rpx;
  color: #5A6B78;
  line-height: 1.5;
}

.address-empty {
  padding: 16rpx 40rpx 16rpx 0;
}

.address-empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.address-empty-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A9BA8;
}

.arrow-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* 商品列表 */
.products-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A4A;
  margin-bottom: 24rpx;
}

.product-list {
  border-top: 1rpx solid #F0F4F5;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F4F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #F5F9FA;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #1A3A4A;
  margin-bottom: 12rpx;
  display: block;
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #DC143C;
}

.product-quantity {
  font-size: 26rpx;
  color: #8A9BA8;
  min-width: 60rpx;
  text-align: right;
}

/* 配送信息 */
.delivery-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.delivery-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.delivery-row:first-child {
  border-bottom: 1rpx solid #F0F4F5;
}

.delivery-label {
  font-size: 28rpx;
  color: #5A6B78;
}

.delivery-value {
  font-size: 28rpx;
  color: #1A3A4A;
}

.delivery-value.free {
  color: #52C41A;
}

.delivery-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A9BA8;
}

/* 备注 */
.remark-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.remark-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.remark-label {
  font-size: 28rpx;
  color: #5A6B78;
  white-space: nowrap;
}

.remark-helper {
  font-size: 24rpx;
  color: #8A9BA8;
}

.remark-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.remark-preset {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #F5F7F8;
  font-size: 24rpx;
  color: #5A6B78;
}

.remark-preset.active {
  background: rgba(220, 20, 60, 0.12);
  color: #DC143C;
  font-weight: 600;
}

.remark-input {
  display: block;
  width: 100%;
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #1A3A4A;
  min-height: 72rpx;
}

/* 价格汇总 */
.price-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.price-row.total {
  border-top: 2rpx solid #F0F4F5;
  margin-top: 16rpx;
  padding-top: 24rpx;
}

.price-label {
  font-size: 28rpx;
  color: #5A6B78;
}

.price-value {
  font-size: 28rpx;
  color: #1A3A4A;
}

.price-total {
  font-size: 36rpx;
  font-weight: 700;
  color: #DC143C;
}

/* 底部提交栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.bottom-info {
  display: flex;
  align-items: baseline;
}

.bottom-label {
  font-size: 28rpx;
  color: #5A6B78;
}

.bottom-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #DC143C;
}

.submit-btn {
  background: #DC143C;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  border: none;
  line-height: 1.5;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}
