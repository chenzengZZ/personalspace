.page {
  min-height: 100vh;
  position: relative;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  overflow-x: hidden;
}

.hero-section {
  position: relative;
  height: 50vh;
  min-height: 400rpx;
  max-height: 600rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  min-height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.2) 40%,
    rgba(0, 0, 0, 0.35) 70%,
    rgba(0, 0, 0, 0.5) 100%
  );
}

.hero-content {
  position: absolute;
  bottom: 140rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.hero-line {
  font-family: "Georgia", "Times New Roman", "Songti SC", serif;
  color: #FFFFFF;
  text-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.5);
  opacity: 0;
  animation: fadeInUp 1s ease forwards;
}

.hero-line-1 {
  font-size: 72rpx;
  font-weight: 400;
  letter-spacing: 12rpx;
  margin-right: 60rpx;
  margin-bottom: 8rpx;
  animation-delay: 0.2s;
}

.hero-line-2 {
  font-size: 72rpx;
  font-weight: 400;
  letter-spacing: 12rpx;
  margin-left: 80rpx;
  animation-delay: 0.4s;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-transition {
  position: absolute;
  bottom: -60rpx;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  z-index: 3;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.product-section {
  position: relative;
  background-color: #ffffff;
  padding-bottom: 20rpx;
  margin-top: -60rpx;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  z-index: 4;
}

.section-header {
  padding: 40rpx 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A3A4A;
  letter-spacing: 2rpx;
  position: relative;
  padding: 0 24rpx;
}

.section-title::before,
.section-title::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 1rpx;
  background-color: #DC143C;
}

.section-title::before {
  left: -40rpx;
}

.section-title::after {
  right: -40rpx;
}

.search-bar {
  padding: 0 24rpx 20rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f7f8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1A3A4A;
}

.search-clear {
  font-size: 32rpx;
  color: #8A9BA8;
  padding: 0 8rpx;
}

.category-tabs {
  display: flex;
  padding: 0 24rpx 24rpx;
  gap: 16rpx;
}

.category-tab {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #5A6A78;
  background: #f5f7f8;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.category-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  box-shadow: 0 2rpx 10rpx rgba(220, 20, 60, 0.3);
}

.product-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 20rpx;
}

.product-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.product-card:active {
  transform: scale(0.96);
}

.product-img {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #f0f4f5 0%, #e5eef0 100%);
}

.product-info {
  padding: 12rpx 14rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A3A4A;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-sales {
  font-size: 20rpx;
  color: #8A9BA8;
  margin-bottom: 10rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #DC143C;
  font-variant-numeric: tabular-nums;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 300;
  box-shadow: 0 2rpx 10rpx rgba(220, 20, 60, 0.3);
  transition: transform 0.2s ease;
}

.add-btn:active {
  transform: scale(0.9);
}

.empty-products {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #8A9BA8;
}

.loading {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #8A9BA8;
}

.bottom-safe {
  height: 40rpx;
}
