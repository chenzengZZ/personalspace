<view class="page" style="--status-bar-height: {{statusBarHeight}}px;">
  <view class="hero-section">
    <image class="hero-bg" src="/assets/images/hero-full.jpg" mode="widthFix" aria-label="弱水三千品牌背景图"></image>
    <view class="hero-overlay"></view>
    <view class="hero-content">
      <view class="hero-line hero-line-1">弱水三千，</view>
      <view class="hero-line hero-line-2">取一瓢饮。</view>
    </view>
    <view class="hero-transition"></view>
  </view>

  <view class="product-section">
    <view class="section-header">
      <view class="section-title">在销商品</view>
    </view>

    <view class="search-bar">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input 
          class="search-input" 
          placeholder="搜索商品" 
          value="{{searchKeyword}}"
          bindinput="onSearch"
          confirm-type="search"
          aria-label="搜索商品"
        />
        <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</text>
      </view>
    </view>

    <view class="category-tabs">
      <view 
        class="category-tab {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="onCategoryChange"
        data-id="{{item.id}}"
        aria-label="筛选{{item.name}}"
      >
        {{item.name}}
      </view>
    </view>

    <view class="product-list" wx:if="{{products.length > 0}}">
      <view class="product-card" wx:for="{{products}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
        <image class="product-img" src="{{item.image}}" mode="aspectFill" aria-label="{{item.name}}"></image>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-sales">已售 {{item.sales}}</view>
          <view class="product-bottom">
            <text class="product-price">¥{{item.price}}</text>
            <view class="add-btn" catchtap="addToCart" data-id="{{item._id}}" aria-label="添加到购物车">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-products" wx:elif="{{!loading}}">
      <text class="empty-text">暂无相关商品</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
