.container {
  min-height: 100vh;
  background: #f5f9fa;
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.page-header {
  padding: 12rpx 8rpx 28rpx;
}

.header-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a3a4a;
}

.header-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8a9ba8;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 2rpx solid transparent;
}

.address-card.selected {
  border-color: #dc143c;
  box-shadow: 0 10rpx 28rpx rgba(220, 20, 60, 0.12);
}

.address-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a3a4a;
}

.phone {
  font-size: 26rpx;
  color: #5a6b78;
}

.status-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.default-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(220, 20, 60, 0.12);
  color: #dc143c;
  font-size: 22rpx;
  font-weight: 600;
}

.check-icon {
  width: 32rpx;
  height: 32rpx;
}

.address-text {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #5a6b78;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf2f7;
}

.action-button {
  min-width: 132rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f6f8fb;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-button.danger {
  background: rgba(220, 20, 60, 0.08);
}

.action-text {
  font-size: 24rpx;
  color: #5a6b78;
}

.action-text.active {
  color: #dc143c;
  font-weight: 600;
}

.danger-text {
  color: #dc143c;
}

.delete-icon {
  width: 24rpx;
  height: 24rpx;
}

.empty-state {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 220rpx;
  opacity: 0.95;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a3a4a;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a9ba8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -6rpx 24rpx rgba(15, 23, 42, 0.06);
}

.add-btn {
  background: #dc143c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  border-radius: 999rpx;
  border: none;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.add-btn::after {
  border: none;
}
