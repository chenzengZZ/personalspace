<view class="container">
  <view class="page-header">
    <text class="header-title">{{isSelectMode ? '选择收货地址' : '管理收货地址'}}</text>
    <text class="header-desc">{{isSelectMode ? '请选择本次订单使用的地址' : '你可以新增、编辑、删除和设置默认地址'}}</text>
  </view>

  <view class="address-list" wx:if="{{addresses.length > 0}}">
    <view
      class="address-card {{isSelectMode && currentId === item._id ? 'selected' : ''}}"
      wx:for="{{addresses}}"
      wx:key="_id"
      bindtap="selectAddress"
      data-id="{{item._id}}"
    >
      <view class="address-main">
        <view class="address-top">
          <view class="user-info">
            <text class="name">{{item.name}}</text>
            <text class="phone">{{item.phone}}</text>
          </view>
          <view class="status-area">
            <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
            <image
              wx:if="{{isSelectMode && currentId === item._id}}"
              class="check-icon"
              src="/assets/icons/check.png"
              mode="aspectFit"
            />
          </view>
        </view>
        <text class="address-text">{{item.fullAddress}}</text>
      </view>

      <view class="card-actions" wx:if="{{!isSelectMode}}">
        <view class="action-button" catchtap="setAsDefault" data-id="{{item._id}}">
          <text class="action-text {{item.isDefault ? 'active' : ''}}">{{item.isDefault ? '默认地址' : '设为默认'}}</text>
        </view>
        <view class="action-button" catchtap="goToEditAddress" data-id="{{item._id}}">
          <text class="action-text">编辑</text>
        </view>
        <view class="action-button danger" catchtap="deleteAddress" data-id="{{item._id}}">
          <image class="delete-icon" src="/assets/icons/delete.png" mode="aspectFit" />
          <text class="action-text danger-text">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <image class="empty-image" src="/assets/icons/empty.png" mode="aspectFit" />
    <text class="empty-title">还没有收货地址</text>
    <text class="empty-desc">{{isSelectMode ? '先新增一个地址，再继续下单' : '新增一个常用地址，后面下单更方便'}}</text>
  </view>

  <view class="bottom-bar">
    <button class="add-btn" bindtap="goToCreateAddress">
      {{isSelectMode ? '新增并使用新地址' : '新增地址'}}
    </button>
  </view>
</view>
