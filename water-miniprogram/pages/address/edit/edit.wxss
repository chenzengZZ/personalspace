.container {
  min-height: 100vh;
  background-color: #F5F9FA;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.page-header {
  padding: 12rpx 8rpx 24rpx;
}

.page-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1A3A4A;
}

.page-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8A9BA8;
}

.form-item {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.form-item.address-detail {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 28rpx;
  color: #5A6B78;
  width: 140rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A3A4A;
  text-align: right;
}

.form-picker {
  flex: 1;
}

.form-picker-text {
  font-size: 28rpx;
  color: #1A3A4A;
  text-align: right;
  display: block;
}

.form-picker-text.placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #1A3A4A;
  margin-top: 20rpx;
  line-height: 1.6;
}

/* 底部保存栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  background: #DC143C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
  line-height: 1.5;
}

.save-btn::after {
  border: none;
}
