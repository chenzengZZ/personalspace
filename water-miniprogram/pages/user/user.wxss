.container {
  min-height: 100vh;
  background: #F5F9FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.user-header {
  margin: 24rpx;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, rgba(220, 20, 60, 0.12) 0%, rgba(184, 18, 46, 0.08) 100%);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(220, 20, 60, 0.08);
  position: relative;
  overflow: hidden;
}

.user-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-header::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(220, 20, 60, 0.15) 0%, rgba(184, 18, 46, 0.1) 100%);
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(220, 20, 60, 0.1);
  border: 3rpx solid rgba(220, 20, 60, 0.2);
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A3A4A;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A3A4A;
  letter-spacing: 1rpx;
  background: transparent;
  padding: 0;
  height: 50rpx;
  line-height: 50rpx;
}

.nickname-input::placeholder {
  color: #8A9BA8;
}

.user-phone {
  font-size: 26rpx;
  color: #8A9BA8;
  letter-spacing: 0.5rpx;
}

.login-btn {
  margin-top: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #DC143C;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.08);
}

.order-section {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(26, 58, 74, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(26, 58, 74, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A4A;
}

.view-all {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #8A9BA8;
}

.arrow-icon {
  font-size: 32rpx;
  margin-left: 8rpx;
  color: #8A9BA8;
}

.order-tabs {
  display: flex;
  padding: 36rpx 0;
}

.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.order-tab:active {
  transform: scale(0.95);
}

.tab-icon {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, rgba(220, 20, 60, 0.1) 0%, rgba(184, 18, 46, 0.05) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 32rpx;
}

.badge {
  position: absolute;
  top: -10rpx;
  right: -14rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #DC143C 0%, #B8122E 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(220, 20, 60, 0.3);
}

.order-tab text {
  font-size: 26rpx;
  color: #8A9BA8;
}

.menu-section {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(26, 58, 74, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(26, 58, 74, 0.06);
  transition: all 0.2s ease;
}

.menu-item:active {
  background: #fafafa;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-text {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #1A3A4A;
}

.menu-arrow {
  font-size: 32rpx;
  color: #8A9BA8;
}

.logout-btn {
  margin: 40rpx 24rpx;
  padding: 28rpx 0;
  text-align: center;
  background: #ffffff;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #8A9BA8;
  font-weight: 500;
  box-shadow: 0 4rpx 20rpx rgba(26, 58, 74, 0.06);
  transition: all 0.2s ease;
}

.logout-btn:active {
  transform: scale(0.98);
  background: #f5f9fa;
}

.dev-section {
  margin: 20rpx 24rpx;
  padding: 20rpx 0;
  text-align: center;
}

.dev-btn {
  font-size: 24rpx;
  color: #8A9BA8;
  padding: 16rpx 32rpx;
  background: rgba(138, 155, 168, 0.1);
  border-radius: 24rpx;
  display: inline-block;
}
