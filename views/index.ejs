<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= data.name %> - 产品运营专家</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <ul class="nav-menu">
        <li><a href="#about">关于我</a></li>
        <li><a href="#experience">工作经历</a></li>
        <li><a href="#projects">项目经历</a></li>
        <li><a href="#skills">技能证书</a></li>
        <li><a href="#summary">个人总结</a></li>
        <li><a href="#contact">联系方式</a></li>
      </ul>
      <a href="#contact" class="nav-cta">联系我</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-badge">产品运营专家</div>
        <h1 class="hero-title">
          你好，我是<span class="highlight"><%= data.name %></span>
        </h1>
        <p class="hero-desc"><%= data.summary %></p>
        <div class="hero-tags">
          <span class="tag">产品全链路运营</span>
          <span class="tag">项目管理</span>
          <span class="tag">合规风控</span>
        </div>
        <div class="hero-actions">
          <a href="#experience" class="btn btn-primary">查看经历</a>
          <a href="#contact" class="btn btn-secondary">联系我</a>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-wrapper">
          <img src="<%= data.avatar %>" alt="<%= data.name %>">
        </div>
      </div>
    </div>
    <div class="scroll-indicator">
      <span>向下滚动</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <section id="about" class="about-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">ABOUT ME</span>
        <h2 class="section-title">关于我</h2>
      </div>
      <div class="about-grid">
        <div class="about-card">
          <div class="about-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3>产品全链路运营</h3>
          <p>具备完整的产品运营经验，从需求分析、方案设计到落地复盘，实现全闭环管理</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="21" x2="9" y2="9"></line>
            </svg>
          </div>
          <h3>项目管理专家</h3>
          <p>统筹跨业务线项目，协调多方资源，保障项目进度与交付质量</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h3>合规风控管理</h3>
          <p>熟悉内容审核规则与质量管理，具备完善的合规风控意识与执行能力</p>
        </div>
      </div>
    </div>
  </section>

  <section id="experience" class="experience-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">EXPERIENCE</span>
        <h2 class="section-title">工作经历</h2>
      </div>
      <div class="timeline">
        <% data.experience.forEach((exp, index) => { %>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div class="company-info">
                <h3 class="company-name"><%= exp.company %></h3>
                <span class="job-title"><%= exp.position %></span>
              </div>
              <span class="timeline-date"><%= exp.period %></span>
            </div>
            <ul class="timeline-details">
              <% exp.details.forEach(detail => { %>
              <li><%= detail %></li>
              <% }); %>
            </ul>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section id="projects" class="projects-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">PROJECTS</span>
        <h2 class="section-title">项目经历</h2>
      </div>
      <div class="projects-grid">
        <% data.projects.forEach((project, index) => { %>
        <div class="project-card">
          <div class="project-header">
            <span class="project-role"><%= project.role %></span>
            <span class="project-date"><%= project.period %></span>
          </div>
          <h3 class="project-title"><%= project.name %></h3>
          <ul class="project-details">
            <% project.details.forEach(detail => { %>
            <li><%= detail %></li>
            <% }); %>
          </ul>
          <% if (project.metrics) { %>
          <div class="project-metrics">
            <% project.metrics.forEach(metric => { %>
            <div class="metric-item">
              <span class="metric-value"><%= metric.value %></span>
              <span class="metric-label"><%= metric.label %></span>
            </div>
            <% }); %>
          </div>
          <% } %>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section id="skills" class="skills-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">SKILLS</span>
        <h2 class="section-title">技能与证书</h2>
      </div>
      <div class="skills-grid">
        <div class="skill-category">
          <div class="skill-tags">
            <% data.certificates.forEach(cert => { %>
            <span class="skill-tag"><%= cert %></span>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="summary" class="summary-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">SUMMARY</span>
        <h2 class="section-title">个人总结</h2>
      </div>
      <div class="summary-card-large">
        <div class="skill-tags">
          <% data.coreSkills.forEach(skill => { %>
          <span class="skill-tag"><%= skill %></span>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <section id="education" class="education-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">EDUCATION</span>
        <h2 class="section-title">教育背景</h2>
      </div>
      <div class="education-card">
        <div class="education-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
          </svg>
        </div>
        <div class="education-info">
          <h3><%= data.education.school %></h3>
          <p class="education-major"><%= data.education.major %> · <%= data.education.degree %></p>
          <p class="education-period"><%= data.education.period %></p>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="contact-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">CONTACT</span>
        <h2 class="section-title">联系方式</h2>
      </div>
      <div class="contact-grid">
        <a href="tel:<%= data.contact.phone %>" class="contact-card">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <span class="contact-label">电话</span>
          <span class="contact-value"><%= data.contact.phone %></span>
        </a>
        <a href="mailto:<%= data.contact.email %>" class="contact-card">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <span class="contact-label">邮箱</span>
          <span class="contact-value"><%= data.contact.email %></span>
        </a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2025 <%= data.name %>. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
